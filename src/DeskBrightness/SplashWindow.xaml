<Window x:Class="DeskBrightness.SplashWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="DeskBrightness" Width="360" Height="220"
  WindowStartupLocation="CenterScreen" WindowStyle="None"
  ResizeMode="NoResize" Background="Transparent" Topmost="True"
  AllowsTransparency="True">
  <Grid>
    <Border CornerRadius="16" Background="#2B2B3D" Padding="36"
      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
      BorderThickness="1">
      <Grid>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Image Width="48" Height="48" HorizontalAlignment="Center"
          Source="{DynamicResource AppIcon}" />

        <TextBlock Grid.Row="1" Text="DeskBrightness" FontSize="24"
          FontWeight="SemiBold" Foreground="#FFFFFF"
          HorizontalAlignment="Center" Margin="0,16,0,0" />

        <TextBlock Grid.Row="2" Text="{DynamicResource AppSubtitle}"
          FontSize="12" Foreground="#A0A0C0"
          HorizontalAlignment="Center" Margin="0,6,0,0"
          TextTrimming="CharacterEllipsis" />

        <StackPanel Grid.Row="3" VerticalAlignment="Center"
          HorizontalAlignment="Center" Margin="0,32,0,0">
          <ProgressBar IsIndeterminate="True" Height="3" Width="200"
            Foreground="{DynamicResource {x:Static SystemColors.AccentColorBrushKey}}"
            Background="#3B3B52" />
        </StackPanel>
      </Grid>
    </Border>
  </Grid>
</Window>
