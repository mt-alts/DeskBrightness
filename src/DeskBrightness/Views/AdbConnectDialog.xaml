<Window
  x:Class="DeskBrightness.Views.AdbConnectDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="{DynamicResource TcpIpDialogTitle}"
  MinHeight="0"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  SizeToContent="WidthAndHeight"
  WindowStartupLocation="CenterOwner"
>
  <Grid Margin="22,22,22,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="14" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource TcpIpDialogHeader}" />
      <TextBlock
        Margin="0,4,0,0"
        FontSize="12"
        Opacity="0.72"
        Text="{DynamicResource TcpIpDialogDescription}"
      />
    </StackPanel>

    <StackPanel Grid.Row="2">
      <TextBlock Margin="0,0,0,6" Text="{DynamicResource IpAddress}" />
      <TextBox
        x:Name="IpAddressTextBox"
        Height="40"
        Padding="10,0"
        VerticalContentAlignment="Center"
      />
    </StackPanel>

    <StackPanel Grid.Row="4">
      <TextBlock Margin="0,0,0,6" Text="{DynamicResource Port}" />
      <TextBox x:Name="PortTextBox" Height="40" Padding="10,0" VerticalContentAlignment="Center" />
    </StackPanel>

    <TextBlock
      x:Name="ErrorTextBlock"
      Grid.Row="5"
      MinHeight="34"
      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
      TextWrapping="Wrap"
    />

    <StackPanel Grid.Row="6" Margin="0,18,0,0">
      <Button
        Height="40"
        Margin="0,0,0,8"
        Padding="14,0"
        HorizontalAlignment="Stretch"
        Click="ConnectButton_Click"
        Content="{DynamicResource TryConnect}"
        FontSize="14"
        FontWeight="SemiBold"
        IsDefault="True"
        Style="{DynamicResource AccentButtonStyle}"
      />

      <Button
        Height="40"
        Padding="14,0"
        HorizontalAlignment="Stretch"
        Click="CancelButton_Click"
        Content="{DynamicResource CancelButton}"
        FontSize="14"
        IsCancel="True"
      />
    </StackPanel>
  </Grid>
</Window>
