<Window
  x:Class="DeskBrightness.Views.AdbPairDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  Title="{DynamicResource PairDialogTitle}"
  MinHeight="0"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  SizeToContent="WidthAndHeight"
  WindowStartupLocation="CenterOwner"
  mc:Ignorable="d"
>
  <Grid Margin="22,22,22,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="14" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="14" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock FontSize="18" FontWeight="SemiBold" Text="{DynamicResource PairDialogHeader}" />
      <TextBlock
        Margin="0,4,0,0"
        FontSize="12"
        Opacity="0.72"
        Text="{DynamicResource PairDialogDescription}"
        TextWrapping="Wrap"
      />
    </StackPanel>

    <StackPanel Grid.Row="2">
      <TextBlock Margin="0,0,0,6" Text="{DynamicResource IpAddress}" />
      <TextBox
        x:Name="IpAddressTextBox"
        Height="40"
        Padding="10,0"
        VerticalContentAlignment="Center"
      />
    </StackPanel>

    <StackPanel Grid.Row="4">
      <TextBlock Margin="0,0,0,6" Text="{DynamicResource Port}" />
      <TextBox x:Name="PortTextBox" Height="40" Padding="10,0" VerticalContentAlignment="Center" />
    </StackPanel>

    <StackPanel Grid.Row="6">
      <TextBlock Margin="0,0,0,6" Text="{DynamicResource PairingCode}" />
      <TextBox
        x:Name="PairingCodeTextBox"
        Height="40"
        Padding="10,0"
        VerticalContentAlignment="Center"
      />
    </StackPanel>

    <StackPanel Grid.Row="8" Margin="0,18,0,0">
      <TextBlock
        x:Name="ErrorTextBlock"
        Margin="0,0,0,10"
        FontSize="12"
        Foreground="{DynamicResource SystemFillColorCriticalBrush}"
        TextWrapping="Wrap"
      />

      <Button
        Height="40"
        Margin="0,0,0,8"
        Padding="14,0"
        Click="TryPair_Click"
        Content="{DynamicResource TryPair}"
        IsDefault="True"
        HorizontalAlignment="Stretch"
        FontSize="14"
        FontWeight="SemiBold"
        Style="{DynamicResource AccentButtonStyle}"
      />

      <Button
        Height="40"
        Padding="14,0"
        Click="Cancel_Click"
        Content="{DynamicResource CancelButton}"
        IsCancel="True"
        HorizontalAlignment="Stretch"
        FontSize="14"
      />
    </StackPanel>
  </Grid>
</Window>
