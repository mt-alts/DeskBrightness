<Window
  x:Class="DeskBrightness.Views.UpdateDialog"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  Title="{DynamicResource UpdateDialogTitle}"
  Width="440"
  MinWidth="440"
  MinHeight="0"
  ResizeMode="NoResize"
  ShowInTaskbar="False"
  SizeToContent="Height"
  WindowStartupLocation="CenterOwner"
  Background="{DynamicResource ControlFillColorDefaultBrush}"
>
  <Grid Margin="24,22,24,24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="16" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="20" />
      <RowDefinition Height="Auto" />
      <RowDefinition Height="18" />
      <RowDefinition Height="Auto" />
    </Grid.RowDefinitions>

    <StackPanel Grid.Row="0">
      <TextBlock
        FontSize="18"
        FontWeight="SemiBold"
        Text="{DynamicResource UpdateDialogTitle}" />
      <TextBlock
        Margin="0,4,0,0"
        FontSize="12"
        Opacity="0.72"
        Text="{DynamicResource UpdateDialogDescription}" />
    </StackPanel>

    <Border Grid.Row="2" Padding="14" CornerRadius="8" Background="{DynamicResource ControlAltFillColorSecondaryBrush}">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="Auto" />
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="6" />
          <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock FontSize="12" Opacity="0.7" Text="{DynamicResource UpdateDialogCurrentVersion}" />
        <TextBlock Grid.Row="2" FontSize="14" FontWeight="SemiBold" Text="{Binding AppVersion, StringFormat='v{0}'}" />

        <StackPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right">
          <TextBlock FontSize="12" Opacity="0.7" Text="{DynamicResource UpdateDialogNewVersion}" />
        </StackPanel>
        <TextBlock Grid.Row="2" Grid.Column="1" FontSize="14" FontWeight="SemiBold" HorizontalAlignment="Right" Foreground="#10B981" Text="{Binding LatestVersion}" />
      </Grid>
    </Border>

    <TextBlock
      x:Name="ErrorTextBlock"
      Grid.Row="4"
      MinHeight="34"
      Foreground="{DynamicResource SystemFillColorCriticalBrush}"
      TextWrapping="Wrap" />

    <Grid Grid.Row="6">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*" />
        <ColumnDefinition Width="Auto" />
        <ColumnDefinition Width="10" />
        <ColumnDefinition Width="Auto" />
      </Grid.ColumnDefinitions>

      <Button
        Grid.Column="1"
        Height="38"
        Padding="14,0"
        Click="SkipButton_Click"
        Content="{DynamicResource UpdateDialogSkip}"
        IsCancel="True"
        FontSize="13"
        FontWeight="SemiBold"
      />

      <Button
        Grid.Column="3"
        Height="38"
        Padding="14,0"
        Click="DownloadButton_Click"
        Content="{DynamicResource UpdateDialogDownload}"
        IsDefault="True"
        FontSize="13"
        FontWeight="SemiBold"
      />
    </Grid>
  </Grid>
</Window>