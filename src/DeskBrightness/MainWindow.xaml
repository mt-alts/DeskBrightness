<Window
  x:Class="DeskBrightness.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
  xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
  xmlns:controls="clr-namespace:DeskBrightness.Controls"
  Title="{DynamicResource AppTitle}"
  Width="420"
  Height="780"
  MinWidth="400"
  MinHeight="740"
  ResizeMode="CanMinimize"
  WindowStartupLocation="CenterScreen"
  mc:Ignorable="d"
>
  <Window.Resources>
    <Style x:Key="MainPageStyle" TargetType="Grid">
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsHelpOpen}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="HeaderStyle" TargetType="Grid">
      <Setter Property="Visibility" Value="Visible" />
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
        <DataTrigger Binding="{Binding IsHelpOpen}" Value="True">
          <Setter Property="Visibility" Value="Collapsed" />
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="SettingsPageStyle" TargetType="Grid">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform Y="30" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsSettingsOpen}" Value="True">
          <Setter Property="IsHitTestVisible" Value="True" />
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25" />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                  To="0"
                  Duration="0:0:0.25"
                />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                  To="30"
                  Duration="0:0:0.2"
                />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="HelpPageStyle" TargetType="Grid">
      <Setter Property="Opacity" Value="0" />
      <Setter Property="IsHitTestVisible" Value="False" />
      <Setter Property="RenderTransform">
        <Setter.Value>
          <TranslateTransform Y="30" />
        </Setter.Value>
      </Setter>
      <Style.Triggers>
        <DataTrigger Binding="{Binding IsHelpOpen}" Value="True">
          <Setter Property="IsHitTestVisible" Value="True" />
          <DataTrigger.EnterActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.25" />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                  To="0"
                  Duration="0:0:0.25"
                />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.EnterActions>
          <DataTrigger.ExitActions>
            <BeginStoryboard>
              <Storyboard>
                <DoubleAnimation Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.2" />
                <DoubleAnimation
                  Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                  To="30"
                  Duration="0:0:0.2"
                />
              </Storyboard>
            </BeginStoryboard>
          </DataTrigger.ExitActions>
        </DataTrigger>
      </Style.Triggers>
    </Style>

    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource ControlStrokeColorDefaultBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="12" />
      <Setter Property="Padding" Value="20" />
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>

    <Style x:Key="CardTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="13" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,8" />
    </Style>

    <Style x:Key="CardValueStyle" TargetType="TextBlock">
      <Setter Property="HorizontalAlignment" Value="Right" />
      <Setter Property="VerticalAlignment" Value="Bottom" />
      <Setter Property="FontSize" Value="12" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Opacity" Value="0.78" />
    </Style>

    <DropShadowEffect
      x:Key="ThumbShadow"
      BlurRadius="4"
      ShadowDepth="1"
      Opacity="0.3"
      Color="#000000"
    />

    <Style x:Key="ToggleSwitchStyle" TargetType="ToggleButton">
      <Setter Property="Width" Value="40" />
      <Setter Property="Height" Value="20" />
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ToggleButton">
            <Grid>
              <Border
                x:Name="TrackOff"
                Width="40"
                Height="20"
                CornerRadius="10"
                Background="{DynamicResource {x:Static SystemColors.ControlBrushKey}}"
                BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
              />
              <Border
                x:Name="TrackOn"
                Width="40"
                Height="20"
                CornerRadius="10"
                Background="{DynamicResource {x:Static SystemColors.AccentColorBrushKey}}"
                BorderBrush="{DynamicResource {x:Static SystemColors.AccentColorBrushKey}}"
                BorderThickness="1"
                Opacity="0"
              />
              <Border
                x:Name="Thumb"
                Width="12"
                Height="12"
                HorizontalAlignment="Left"
                Margin="4,4,0,4"
                Background="{DynamicResource {x:Static SystemColors.ControlDarkBrushKey}}"
                CornerRadius="6"
                Effect="{StaticResource ThumbShadow}"
              />
            </Grid>
            <ControlTemplate.Triggers>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="TrackOff" Property="Opacity" Value="0" />
                <Setter TargetName="TrackOn" Property="Opacity" Value="1" />
                <Setter TargetName="Thumb" Property="HorizontalAlignment" Value="Right" />
                <Setter TargetName="Thumb" Property="Margin" Value="0,4,4,4" />
                <Setter
                  TargetName="Thumb"
                  Property="Background"
                  Value="{DynamicResource {x:Static SystemColors.HighlightTextBrushKey}}"
                />
              </Trigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True" />
                  <Condition Property="IsChecked" Value="False" />
                </MultiTrigger.Conditions>
                <Setter
                  TargetName="TrackOff"
                  Property="Background"
                  Value="{DynamicResource {x:Static SystemColors.ControlLightBrushKey}}"
                />
              </MultiTrigger>
              <MultiTrigger>
                <MultiTrigger.Conditions>
                  <Condition Property="IsMouseOver" Value="True" />
                  <Condition Property="IsChecked" Value="True" />
                </MultiTrigger.Conditions>
                <Setter
                  TargetName="TrackOn"
                  Property="Background"
                  Value="{DynamicResource {x:Static SystemColors.AccentColorLight1BrushKey}}"
                />
                <Setter
                  TargetName="TrackOn"
                  Property="BorderBrush"
                  Value="{DynamicResource {x:Static SystemColors.AccentColorLight1BrushKey}}"
                />
              </MultiTrigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="TrackOff" Property="Opacity" Value="0.3" />
                <Setter TargetName="TrackOn" Property="Opacity" Value="0.3" />
                <Setter TargetName="Thumb" Property="Opacity" Value="0.3" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style
      x:Key="DeviceComboBoxItemStyle"
      TargetType="ComboBoxItem"
      BasedOn="{StaticResource {x:Type ComboBoxItem}}"
    >
      <Setter Property="IsEnabled" Value="{Binding CanSelect}" />
      <Setter Property="ToolTip" Value="{Binding WarningText}" />
    </Style>
  </Window.Resources>

  <Canvas>
    <Grid Canvas.Left="24" Canvas.Top="24" Width="372" Height="732">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <Grid Grid.Row="0" Margin="0,0,0,20" Style="{StaticResource HeaderStyle}">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="48" />
          <ColumnDefinition Width="*" />
          <ColumnDefinition Width="40" />
          <ColumnDefinition Width="40" />
        </Grid.ColumnDefinitions>

        <Image Margin="0,0,10,0" Source="{DynamicResource AppIcon}" />

        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock FontSize="24" FontWeight="SemiBold" Text="{DynamicResource AppTitle}" />
          <TextBlock
            Margin="0,3,0,0"
            FontSize="12"
            Text="{DynamicResource AppSubtitle}"
            TextWrapping="Wrap"
          />
        </StackPanel>

        <Button
          Background="Transparent"
          BorderBrush="Transparent"
          Grid.Column="2"
          Width="36"
          Height="36"
          Padding="0"
          Command="{Binding OpenHelpCommand}"
          ToolTip="{DynamicResource HelpTooltip}"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE897;" />
        </Button>

        <Button
          Background="Transparent"
          BorderBrush="Transparent"
          Grid.Column="3"
          Width="36"
          Height="36"
          Padding="0"
          Command="{Binding OpenSettingsCommand}"
          ToolTip="{DynamicResource SettingsTitle}"
        >
          <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="16" Text="&#xE713;" />
        </Button>
      </Grid>

      <Grid Grid.Row="1" Style="{StaticResource MainPageStyle}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
          <StackPanel>
            <TextBlock
              Margin="0,0,0,12"
              Style="{StaticResource CardTitleStyle}"
              Text="{DynamicResource AdbDeviceTitle}"
            />
            <Grid IsEnabled="{Binding IsRunning, Converter={StaticResource BoolInverter}}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="10" />
                <ColumnDefinition Width="36" />
                <ColumnDefinition Width="8" />
                <ColumnDefinition Width="36" />
              </Grid.ColumnDefinitions>

              <ComboBox
                Grid.Column="0"
                Height="38"
                DisplayMemberPath="DisplayName"
                ItemContainerStyle="{StaticResource DeviceComboBoxItemStyle}"
                ItemsSource="{Binding Devices}"
                SelectedItem="{Binding SelectedDevice, Mode=TwoWay}"
              />

              <Button
                Grid.Column="2"
                Width="38"
                Height="38"
                Padding="0"
                Command="{Binding DiscoverDevicesCommand}"
                ToolTip="{DynamicResource RefreshTooltip}"
              >
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE72C;" />
              </Button>

              <Button
                Grid.Column="4"
                Width="38"
                Height="38"
                Padding="0"
                Click="AddDeviceButton_Click"
                ToolTip="{DynamicResource AddTooltip}"
              >
                <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE710;" />
                <Button.ContextMenu>
                  <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                    <MenuItem
                      Command="{Binding AddDeviceCommand}"
                      Header="{DynamicResource TcpIpMenuItem}"
                    />
                    <MenuItem
                      Command="{Binding PairDeviceCommand}"
                      Header="{DynamicResource PairMenuItem}"
                    />
                  </ContextMenu>
                </Button.ContextMenu>
              </Button>
            </Grid>
          </StackPanel>
        </Border>

        <Border Grid.Row="1" Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="8" />
              <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Style="{StaticResource CardTitleStyle}"
                Text="{DynamicResource BrightnessTitle}"
              />
              <TextBlock
                Grid.Column="1"
                VerticalAlignment="Bottom"
                FontSize="14"
                FontWeight="SemiBold"
                Text="{Binding Brightness}"
              />
            </Grid>

            <Slider
              x:Name="BrightnessSlider"
              Grid.Row="2"
              IsHitTestVisible="False"
              Maximum="100"
              Minimum="0"
              Value="0"
              TickFrequency="10"
            />
          </Grid>
        </Border>

        <Grid Grid.Row="2" Margin="0,2,0,12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*" />
            <ColumnDefinition Width="12" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button
            Grid.Column="0"
            Height="40"
            MinHeight="40"
            Padding="14,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Command="{Binding StartCommand}"
            Content="{DynamicResource ConnectButton}"
            FontSize="14"
            FontWeight="SemiBold"
            Style="{DynamicResource AccentButtonStyle}"
          />

          <Button
            Grid.Column="2"
            Height="40"
            MinHeight="40"
            Padding="14,0"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Center"
            HorizontalContentAlignment="Center"
            VerticalContentAlignment="Center"
            Command="{Binding StopCommand}"
            Content="{DynamicResource CancelButton}"
            FontSize="14"
            FontWeight="SemiBold"
            Style="{DynamicResource AccentButtonStyle}"
          />
        </Grid>

        <Border Grid.Row="4" Margin="0" Style="{StaticResource CardStyle}">
          <Grid>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto" />
              <RowDefinition Height="*" />
            </Grid.RowDefinitions>
            <Grid Margin="0,0,0,10">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>
              <TextBlock
                Style="{StaticResource CardTitleStyle}"
                Text="{DynamicResource LogsTitle}"
              />
            </Grid>
            <TextBox
              Grid.Row="1"
              Padding="0"
              FontFamily="Consolas"
              FontSize="11"
              IsReadOnly="True"
              ScrollViewer.HorizontalScrollBarVisibility="Disabled"
              ScrollViewer.VerticalScrollBarVisibility="Auto"
              Text="{Binding LogText, Mode=OneWay}"
              TextWrapping="Wrap"
            />
          </Grid>
        </Border>
      </Grid>

      <Grid Grid.Row="1" Style="{StaticResource SettingsPageStyle}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button
            Grid.Column="0"
            Width="36"
            Height="36"
            Padding="0"
            Background="Transparent"
            BorderBrush="Transparent"
            Command="{Binding CloseSettingsCommand}"
            ToolTip="{DynamicResource BackTooltip}"
          >
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE72B;" />
          </Button>

          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{DynamicResource SettingsTitle}" />
            <TextBlock
              Margin="0,3,0,0"
              FontSize="12"
              Opacity="0.72"
              Text="{DynamicResource SettingsSubtitle}"
            />
          </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="0,0,12,0" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <!-- ═══ GENERAL ═══ -->
            <TextBlock
              Margin="4,0,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource SettingsSectionGeneral}"
            />

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource Language}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding SelectedLanguage.DisplayName}"
                  />
                </Grid>
                <ComboBox
                  Grid.Row="2"
                  ItemsSource="{Binding AvailableLanguages}"
                  SelectedItem="{Binding SelectedLanguage, Mode=TwoWay}"
                  DisplayMemberPath="DisplayName"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  VerticalAlignment="Center"
                  Margin="0"
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource MinimizeToTray}"
                />
                <ToggleButton
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Style="{StaticResource ToggleSwitchStyle}"
                  IsChecked="{Binding MinimizeToTraySetting, Mode=TwoWay}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  VerticalAlignment="Center"
                  Margin="0"
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource CheckForUpdatesOnStartup}"
                />
                <ToggleButton
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Style="{StaticResource ToggleSwitchStyle}"
                  IsChecked="{Binding CheckForUpdatesOnStartupSetting, Mode=TwoWay}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <TextBlock
                  VerticalAlignment="Center"
                  Margin="0"
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource ShutdownAdbOnExit}"
                />
                <ToggleButton
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Style="{StaticResource ToggleSwitchStyle}"
                  IsChecked="{Binding ShutdownAdbOnExitSetting, Mode=TwoWay}"
                />
              </Grid>
            </Border>

            <!-- ═══ BRIGHTNESS ═══ -->
            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource SettingsSectionBrightness}"
            />

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource MinimumBrightness}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding MinimumBrightnessSetting, StringFormat={}{0}%}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="100"
                  Minimum="0"
                  TickFrequency="1"
                  Value="{Binding MinimumBrightnessSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource MaximumBrightness}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding MaximumBrightnessSetting, StringFormat={}{0}%}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="100"
                  Minimum="0"
                  TickFrequency="1"
                  Value="{Binding MaximumBrightnessSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource LuxThreshold}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding LuxThresholdSetting, StringFormat={}{0:0.0} lux}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="30"
                  Minimum="0"
                  TickFrequency="0.5"
                  Value="{Binding LuxThresholdSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource BrightnessStepThreshold}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding BrightnessStepThresholdSetting, StringFormat={}{0}%}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="30"
                  Minimum="0"
                  TickFrequency="1"
                  Value="{Binding BrightnessStepThresholdSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>

            <!-- ═══ SMOOTHING ═══ -->
            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource SettingsSectionSmoothing}"
            />

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource SmoothingWindowSize}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding SmoothingWindowSizeSetting}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="20"
                  Minimum="1"
                  TickFrequency="1"
                  Value="{Binding SmoothingWindowSizeSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto" />
                  <RowDefinition Height="8" />
                  <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource MinimumApplyInterval}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding MinimumApplyIntervalSecondsSetting, StringFormat={}{0:0.0}s}"
                  />
                </Grid>
                <Slider
                  Grid.Row="2"
                  Margin="0"
                  Maximum="30"
                  Minimum="0.5"
                  TickFrequency="0.5"
                  Value="{Binding MinimumApplyIntervalSecondsSetting, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                />
              </Grid>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>

      <Grid Grid.Row="1" Style="{StaticResource HelpPageStyle}">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto" />
          <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="2,0,2,14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="40" />
            <ColumnDefinition Width="*" />
          </Grid.ColumnDefinitions>

          <Button
            Grid.Column="0"
            Width="36"
            Height="36"
            Padding="0"
            BorderBrush="Transparent"
            Background="Transparent"
            Command="{Binding CloseHelpCommand}"
            ToolTip="{DynamicResource BackTooltip}"
          >
            <TextBlock FontFamily="Segoe MDL2 Assets" FontSize="15" Text="&#xE72B;" />
          </Button>

          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock FontSize="22" FontWeight="SemiBold" Text="{DynamicResource HelpTitle}" />
            <TextBlock
              Margin="0,3,0,0"
              FontSize="12"
              Opacity="0.72"
              Text="{DynamicResource HelpSubtitle}"
            />
          </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" Padding="0,0,12,0" VerticalScrollBarVisibility="Auto">
          <StackPanel>
            <Border Style="{StaticResource CardStyle}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="48" />
                  <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Image Width="40" Height="40" Source="{DynamicResource AppIcon}" />
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                  <TextBlock
                    FontSize="20"
                    FontWeight="SemiBold"
                    Text="{DynamicResource AppTitle}"
                  />
                  <TextBlock
                    Margin="0,2,0,0"
                    FontSize="12"
                    Opacity="0.72"
                    Text="{Binding AppVersion, StringFormat='v{0}'}"
                  />
                </StackPanel>
              </Grid>
            </Border>

            <TextBlock
              Margin="4,0,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource HelpSectionAbout}"
            />

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource HelpAboutTitle}"
                />
                <TextBlock
                  Style="{StaticResource CardValueStyle}"
                  Text="{DynamicResource HelpAboutBody}"
                  TextWrapping="Wrap"
                />
              </StackPanel>
            </Border>

            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource HelpSectionSetup}"
            />

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource HelpSetupStep1Title}"
                />
                <TextBlock
                  Style="{StaticResource CardValueStyle}"
                  Text="{DynamicResource HelpSetupStep1Body}"
                  TextWrapping="Wrap"
                />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource HelpSetupStep2Title}"
                />
                <TextBlock
                  Style="{StaticResource CardValueStyle}"
                  Text="{DynamicResource HelpSetupStep2Body}"
                  TextWrapping="Wrap"
                />
              </StackPanel>
            </Border>

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource HelpSetupStep3Title}"
                />
                <TextBlock
                  Style="{StaticResource CardValueStyle}"
                  Text="{DynamicResource HelpSetupStep3Body}"
                  TextWrapping="Wrap"
                />
              </StackPanel>
            </Border>

            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource HelpSectionUpdates}"
            />

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <TextBlock
                    Style="{StaticResource CardTitleStyle}"
                    Text="{DynamicResource HelpVersionTitle}"
                  />
                  <TextBlock
                    Grid.Column="1"
                    Style="{StaticResource CardValueStyle}"
                    Text="{Binding AppVersion}"
                  />
                </Grid>
                <Button
                  Margin="0,10,0,0"
                  Height="36"
                  Padding="14,0"
                  HorizontalAlignment="Stretch"
                  BorderBrush="Transparent"
                  Command="{Binding CheckForUpdatesCommand}"
                  Content="{DynamicResource HelpCheckUpdatesButton}"
                  FontSize="13"
                  FontWeight="SemiBold"
                />
                <Border
                  Margin="0,10,0,0"
                  Padding="10"
                  BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="6"
                  Visibility="{Binding HasUpdateActivity, Converter={StaticResource BoolToVisibilityConverter}}"
                >
                  <StackPanel>
                    <TextBlock FontSize="11" Opacity="0.72">
                      <TextBlock.Style>
                        <Style TargetType="TextBlock">
                          <Setter Property="Text" Value="{DynamicResource HelpUpdateCheckReady}" />
                          <Style.Triggers>
                            <DataTrigger Binding="{Binding IsCheckingUpdate}" Value="True">
                              <Setter
                                Property="Text"
                                Value="{DynamicResource HelpUpdateChecking}"
                              />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsUpdateAvailable}" Value="True">
                              <Setter
                                Property="Text"
                                Value="{DynamicResource HelpUpdateAvailable}"
                              />
                            </DataTrigger>
                          </Style.Triggers>
                        </Style>
                      </TextBlock.Style>
                    </TextBlock>
                    <TextBlock
                      Margin="0,4,0,0"
                      FontSize="10"
                      Opacity="0.6"
                      Text="{Binding UpdateProgressText}"
                      TextTrimming="CharacterEllipsis"
                    />
                    <ProgressBar
                      Margin="0,8,0,0"
                      Height="4"
                      Value="{Binding UpdateProgress, Mode=OneWay}"
                      Maximum="100"
                      IsIndeterminate="{Binding IsCheckingUpdate, Mode=OneWay}"
                    />
                  </StackPanel>
                </Border>
                <Button
                  Margin="0,8,0,0"
                  Height="36"
                  Padding="14,0"
                  HorizontalAlignment="Stretch"
                  Command="{Binding DownloadLatestCommand}"
                  Content="{DynamicResource HelpDownloadButton}"
                  FontSize="13"
                  FontWeight="SemiBold"
                  IsEnabled="{Binding IsUpdateAvailable}"
                />
              </StackPanel>
            </Border>

            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource HelpSectionThirdParty}"
            />

            <ItemsControl ItemsSource="{Binding ThirdPartyComponents}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border Style="{StaticResource CardStyle}">
                    <StackPanel>
                      <Grid VerticalAlignment="Stretch" HorizontalAlignment="Stretch">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*" />
                          <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock
                          Style="{StaticResource CardTitleStyle}"
                          Text="{Binding Name}"
                          TextTrimming="CharacterEllipsis"
                        />
                        <TextBlock Grid.Column="1" VerticalAlignment="Center" Margin="4,0,0,0">
                          <Hyperlink
                            NavigateUri="{Binding LicenseUrl}"
                            RequestNavigate="Hyperlink_RequestNavigate"
                          >
                            <TextBlock Text="{Binding License}" />
                          </Hyperlink>
                        </TextBlock>
                      </Grid>
                      <TextBlock
                        Style="{StaticResource CardValueStyle}"
                        HorizontalAlignment="Left"
                        Text="{Binding Version}"
                      />
                    </StackPanel>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>

            <TextBlock
              Margin="4,12,0,8"
              FontSize="11"
              FontWeight="SemiBold"
              Text="{DynamicResource HelpSectionLegal}"
            />

            <Border Style="{StaticResource CardStyle}">
              <StackPanel>
                <TextBlock
                  Style="{StaticResource CardTitleStyle}"
                  Text="{DynamicResource HelpCopyrightTitle}"
                />
                <TextBlock
                  Style="{StaticResource CardValueStyle}"
                  Text="{DynamicResource HelpCopyrightBody}"
                  TextWrapping="Wrap"
                />
                <Button
                  Margin="0,10,0,0"
                  Height="36"
                  Padding="14,0"
                  HorizontalAlignment="Stretch"
                  Content="{DynamicResource HelpLicenseLink}"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Click="LicenseButton_Click"
                />
              </StackPanel>
            </Border>
          </StackPanel>
        </ScrollViewer>
      </Grid>
    </Grid>

    <Border
      Panel.ZIndex="100"
      Canvas.Left="20"
      Canvas.Bottom="24"
      Width="380"
      Opacity="0"
      x:Name="Snackbar"
      IsHitTestVisible="False"
      Background="#0D1628"
      BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
      BorderThickness="1"
      CornerRadius="8"
    >
      <controls:InfoBar
        x:Name="SnackbarContent"
        Severity="{Binding CurrentInfoBarMessage.Severity}"
        Title="{Binding CurrentInfoBarMessage.Title}"
        Message="{Binding CurrentInfoBarMessage.Message}"
      />
    </Border>
  </Canvas>
</Window>
